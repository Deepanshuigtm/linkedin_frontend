# Vercel Deployment Configuration
{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://linkdin-automation-backend.onrender.com",
    "VITE_WS_BASE_URL": "wss://linkdin-automation-backend.onrender.com"
  }
}
